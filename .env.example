# =============================================================================
# Berkeley Platform — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# Docker Compose and all agents read from this file.

# ── Network / Node IPs ───────────────────────────────────────────────
# Node 01 = Dell OptiPlex (Control Plane)
# Node 02 = Gigabyte GFCANADA (Compute Node)
NODE01_IP=192.168.1.100
NODE02_IP=192.168.1.101

# ── MQTT (Mosquitto — runs on Node 01) ───────────────────────────────
MQTT_BROKER=${NODE01_IP}
MQTT_PORT=1883
MQTT_ENABLED=true

# ── InfluxDB (runs on Node 01) ────────────────────────────────────────
INFLUXDB_URL=http://${NODE01_IP}:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=berkeley
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=berkeley2024

# ── Home Assistant (VM on Node 01) ───────────────────────────────────
HOME_ASSISTANT_URL=http://${NODE01_IP}:8123
HOME_ASSISTANT_TOKEN=your-long-lived-access-token

# ── Frigate NVR (Docker on Node 01, + Google Coral USB TPU) ──────────
FRIGATE_URL=http://${NODE01_IP}:5000
FRIGATE_RTSP_PASSWORD=changeme

# ── Wyoming Voice Pipeline (LXC on Node 01) ──────────────────────────
WYOMING_HOST=${NODE01_IP}
WYOMING_PORT=10300

# ── Ollama (LXC/VM on Node 02 — RTX 4080 SUPER) ─────────────────────
OLLAMA_URL=http://${NODE02_IP}:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── Earthquake Engine ────────────────────────────────────────────────
SHAKE_IP=192.168.1.164
SHAKE_STATION=R1A3D
SHAKE_NETWORK=AM
SHAKE_CHANNEL=EHZ

# ── Environmental Station ────────────────────────────────────────────
# (reads from MQTT_BROKER, INFLUXDB_URL, INFLUXDB_TOKEN above)

# ── Audio Receiver ───────────────────────────────────────────────────
INGEST_URL=http://${NODE01_IP}:5050/api/ingest

# ── Home Sensors ─────────────────────────────────────────────────────
RACHIO_API_KEY=
RACHIO_DEVICE_ID=

# ── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_URL=http://${NODE01_IP}:5050/api/ingest

# ── Alarm Service (BerkeleyAlarms — Node 01) ─────────────────────────
ALARM_API_PORT=8084
ALARM_DB_PATH=/var/lib/berkeley/alarms.db
ALARMS_CONFIG_PATH=./alarms.yml

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
