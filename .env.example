# =============================================================================
# Berkeley Platform — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# Docker Compose and all agents read from this file.

# ── MQTT (Mosquitto) ─────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_ENABLED=true

# ── InfluxDB ─────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=berkeley
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=berkeley2024

# ── Earthquake Engine ────────────────────────────────────────────────
SHAKE_IP=192.168.4.164
SHAKE_STATION=R1A3D
SHAKE_NETWORK=AM
SHAKE_CHANNEL=EHZ

# ── Environmental Station ────────────────────────────────────────────
# (reads from MQTT_BROKER, INFLUXDB_URL, INFLUXDB_TOKEN above)

# ── Audio Receiver ───────────────────────────────────────────────────
INGEST_URL=http://localhost:5050/api/ingest

# ── Home Sensors ─────────────────────────────────────────────────────
RACHIO_API_KEY=
RACHIO_DEVICE_ID=

# ── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5050/api/ingest

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
